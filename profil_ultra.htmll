</main><!-- /page -->

<!-- ============================================================
     JAVASCRIPT
     ============================================================ -->
<script>
/* ── CURSOR ── */
const dot   = document.getElementById('cur-dot');
const ring  = document.getElementById('cur-ring');
const trail = document.getElementById('cur-trail');
let mx=0,my=0, rx=0,ry=0, tx=0,ty=0;

document.addEventListener('mousemove', e => { mx=e.clientX; my=e.clientY; });

(function cursorLoop(){
  rx += (mx-rx)*.18;
  ry += (my-ry)*.18;
  tx += (mx-tx)*.06;
  ty += (my-ty)*.06;
  dot.style.left   = mx+'px';
  dot.style.top    = my+'px';
  ring.style.left  = rx+'px';
  ring.style.top   = ry+'px';
  trail.style.left = tx+'px';
  trail.style.top  = ty+'px';
  requestAnimationFrame(cursorLoop);
})();

const hoverEls = document.querySelectorAll('a,button,.skill-chip,.vibe-chip,.ach-card,.stat-box,.proj-card,.tl-item,.ava-container,.scard-icon-wrap');
hoverEls.forEach(el=>{
  el.addEventListener('mouseenter',()=>document.body.classList.add('cursor-hover'));
  el.addEventListener('mouseleave',()=>document.body.classList.remove('cursor-hover'));
});

/* ── CANVAS PARTICLE NETWORK ── */
const canvas = document.getElementById('canvas-bg');
const ctx    = canvas.getContext('2d');
let W,H;
function resize(){ W=canvas.width=window.innerWidth; H=canvas.height=window.innerHeight; }
resize();
window.addEventListener('resize',resize);

class Dot {
  constructor(){this.reset();}
  reset(){
    this.x = Math.random()*W;
    this.y = Math.random()*H;
    this.vx= (Math.random()-.5)*.35;
    this.vy= (Math.random()-.5)*.35;
    this.r = Math.random()*1.8+.4;
    this.a = Math.random()*.4+.08;
  }
  update(){
    this.x+=this.vx; this.y+=this.vy;
    if(this.x<0||this.x>W) this.vx*=-1;
    if(this.y<0||this.y>H) this.vy*=-1;
  }
  draw(){
    ctx.beginPath();
    ctx.arc(this.x,this.y,this.r,0,Math.PI*2);
    ctx.fillStyle=`rgba(0,210,255,${this.a})`;
    ctx.fill();
  }
}

const dots=[];
for(let i=0;i<100;i++) dots.push(new Dot());

const LINK=130;
(function loop(){
  ctx.clearRect(0,0,W,H);
  dots.forEach(d=>{d.update();d.draw();});
  for(let i=0;i<dots.length;i++)
    for(let j=i+1;j<dots.length;j++){
      const dx=dots[i].x-dots[j].x, dy=dots[i].y-dots[j].y;
      const dist=Math.sqrt(dx*dx+dy*dy);
      if(dist<LINK){
        ctx.beginPath();
        ctx.moveTo(dots[i].x,dots[i].y);
        ctx.lineTo(dots[j].x,dots[j].y);
        ctx.strokeStyle=`rgba(0,210,255,${.1*(1-dist/LINK)})`;
        ctx.lineWidth=.6;
        ctx.stroke();
      }
    }
  requestAnimationFrame(loop);
})();

/* Mouse interaction with dots */
document.addEventListener('mousemove',e=>{
  dots.forEach(d=>{
    const dx=e.clientX-d.x, dy=e.clientY-d.y;
    const dist=Math.sqrt(dx*dx+dy*dy);
    if(dist<120){
      d.vx -= dx*.002;
      d.vy -= dy*.002;
    }
  });
});

/* ── FLOATING DOM PARTICLES ── */
const pw = document.getElementById('f-particles-wrap');
for(let i=0;i<22;i++){
  const p=document.createElement('div');
  p.className='f-particle';
  const sz=Math.random()*3+1;
  const dur=10+Math.random()*14;
  const del=Math.random()*dur;
  p.style.cssText=`
    width:${sz}px;height:${sz}px;
    left:${Math.random()*100}%;
    animation-duration:${dur}s;
    animation-delay:-${del}s;
    opacity:0;
  `;
  pw.appendChild(p);
}

/* ── LOADER ── */
window.addEventListener('load',()=>{
  setTimeout(()=>{
    document.getElementById('loader').classList.add('done');
    triggerReveal();
  }, 2000);
});

/* ── REVEAL ON SCROLL ── */
function triggerReveal(){
  const revEls=document.querySelectorAll('.reveal');
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        e.target.classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  },{threshold:.08});
  revEls.forEach(el=>obs.observe(el));
}

/* ── COUNT UP ── */
function countUp(el,end,suffix){
  let start=0;
  const dur=1400, step=16;
  const inc=end/(dur/step);
  const t=setInterval(()=>{
    start+=inc;
    if(start>=end){ start=end; clearInterval(t); }
    el.textContent=Math.round(start);
  },step);
}
const countObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      document.querySelectorAll('.count').forEach(el=>{
        const v=parseInt(el.dataset.val);
        countUp(el,v);
      });
      countObs.disconnect();
    }
  });
},{threshold:.5});
const statsRow=document.querySelector('.stats-row');
if(statsRow) countObs.observe(statsRow);

/* ── SKILL BAR ANIMATION ── */
const skillObs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.querySelectorAll('.skill-fill').forEach(f=>{
        setTimeout(()=>{ f.style.width=f.dataset.w+'%'; },200);
      });
      skillObs.unobserve(e.target);
    }
  });
},{threshold:.2});
const skillSec=document.querySelector('.skills-section');
if(skillSec) skillObs.observe(skillSec);

/* ── RIPPLE ON SOCIAL CARDS ── */
document.querySelectorAll('.social-card,.mini-social,.cta-btn').forEach(btn=>{
  btn.addEventListener('click',function(e){
    const r=document.createElement('span');
    r.className='ripple-effect';
    const rect=this.getBoundingClientRect();
    const size=Math.max(rect.width,rect.height);
    r.style.cssText=`width:${size}px;height:${size}px;left:${e.clientX-rect.left-size/2}px;top:${e.clientY-rect.top-size/2}px;`;
    this.appendChild(r);
    setTimeout(()=>r.remove(),700);
  });
});

/* ── LIVE CLOCK ── */
function updateTime(){
  const now=new Date();
  const h=String(now.getHours()).padStart(2,'0');
  const m=String(now.getMinutes()).padStart(2,'0');
  const s=String(now.getSeconds()).padStart(2,'0');
  const el=document.getElementById('live-time');
  if(el) el.textContent=`${h}:${m}:${s} WIB`;
}
updateTime();
setInterval(updateTime,1000);

/* ── GLITCH ON HERO NAME ── */
const heroName=document.getElementById('hero-name');
const origText=heroName?heroName.textContent:'';
const glitchChars='!@#$%&*<>?[]{}|~ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
function glitchText(el,orig){
  let iter=0;
  const iv=setInterval(()=>{
    el.textContent=orig.split('').map((c,i)=>{
      if(c===' ') return ' ';
      if(i<iter) return orig[i];
      return glitchChars[Math.floor(Math.random()*glitchChars.length)];
    }).join('');
    if(iter>=orig.length) clearInterval(iv);
    iter+=.5;
  },30);
}
if(heroName){
  heroName.addEventListener('mouseenter',()=>glitchText(heroName,origText));
}

/* ── AVATAR EMOJI CYCLE ── */
const emojiList=['😎','🤙','🔥','⚡','👾','🚀','💎','🎯'];
let eiIdx=0;
const avaEmoji=document.getElementById('ava-emoji');
if(avaEmoji){
  document.getElementById('avaEl').addEventListener('click',()=>{
    eiIdx=(eiIdx+1)%emojiList.length;
    avaEmoji.style.transform='scale(0)';
    setTimeout(()=>{
      avaEmoji.textContent=emojiList[eiIdx];
      avaEmoji.style.transform='scale(1)';
      avaEmoji.style.transition='transform .3s cubic-bezier(.34,1.56,.64,1)';
    },150);
  });
}

/* ── PARALLAX ORBS ── */
document.addEventListener('mousemove',e=>{
  const px=e.clientX/window.innerWidth-.5;
  const py=e.clientY/window.innerHeight-.5;
  document.querySelectorAll('.bg-orb').forEach((orb,i)=>{
    const s=(i+1)*12;
    orb.style.transform=`translate(${px*s}px,${py*s}px)`;
  });
});

/* ── TYPING INDICATOR in Terminal ── */
(function typeLoop(){
  const cmds=['cat about.json','ls projects/','git status','npm run vibe','echo "Stay based."'];
  let ci=0, chi=0;
  const tCursor=document.querySelector('.t-cursor');
  function nextCmd(){
    ci=(ci+1)%cmds.length;
    chi=0;
  }
  setInterval(()=>{
    if(tCursor) tCursor.dataset.cmd=(cmds[ci]||'').slice(0,chi++);
    if(chi>cmds[ci].length+20){ nextCmd(); }
  },120);
})();

/* ── STATUS PILL COLOR CYCLE ── */
const led=document.querySelector('.status-led');
const colors=['#00e676','#00d2ff','var(--gold)','#00e676'];
let lci=0;
setInterval(()=>{
  lci=(lci+1)%colors.length;
  // subtle shift, mostly stays green
},4000);
</script>
<audio id="djKeong" loop>
  <source src="https://raw.githubusercontent.com/myshdnv2/dj/main/dj/keong.mp3"
  Browser kamu tidak mendukung audio.
</audio>
<script>
  // Fungsi agar lagu berputar saat layar pertama kali disentuh
  document.addEventListener('touchstart', function() {
    var audio = document.querySelector('audio');
    audio.play();
  }, { once: true });

  // Fungsi cadangan untuk klik
  document.addEventListener('click', function() {
    var audio = document.querySelector('audio');
    audio.play();
  }, { once: true });
</script>

</body>
</html>
